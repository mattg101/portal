<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/portal_widget_bg"
    android:gravity="center"
    android:orientation="horizontal"
    android:padding="8dp">

    <ImageButton
        android:id="@+id/portal_widget_media"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/portal_widget_btn_bg"
        android:contentDescription="@string/image"
        android:padding="10dp"
        android:src="@drawable/ic_add_white_24dp"
        android:tint="@color/white" />

    <ImageButton
        android:id="@+id/portal_widget_mic"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/portal_widget_btn_bg_accent"
        android:contentDescription="@string/record_audio"
        android:padding="10dp"
        android:src="@drawable/ic_keyboard_voice_black_24dp"
        android:tint="@color/white" />

    <ImageButton
        android:id="@+id/portal_widget_text"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/portal_widget_btn_bg"
        android:contentDescription="@string/editor"
        android:padding="10dp"
        android:src="@drawable/ic_edit_black_24dp"
        android:tint="@color/white" />

</LinearLayout>
