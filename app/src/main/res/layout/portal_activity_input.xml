<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingTop="10dp">

        <TextView
            android:id="@+id/portal_datetime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:textColor="@color/primary_text"
            android:textSize="20sp" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="120dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <EditText
            android:id="@+id/portal_editor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:gravity="top"
            android:hint="Start writing..."
            android:imeOptions="flagNoExtractUi"
            android:inputType="textCapSentences|textMultiLine"
            android:minHeight="560dp"
            android:padding="20dp"
            android:textColor="@color/primary_text"
            android:textColorHint="@color/secondary_text"
            android:textCursorDrawable="@drawable/cursor_accent"
            android:textSize="20sp" />
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/portal_bottom_toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/primary"
        app:contentInsetStart="12dp"
        app:contentInsetEnd="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/portal_action_media"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/image"
                android:src="@drawable/ic_add_white_24dp"
                app:tint="@color/dark__primary_text" />

            <ImageButton
                android:id="@+id/portal_action_mic"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@string/record_audio"
                android:src="@drawable/ic_keyboard_voice_black_24dp"
                app:tint="@color/accent" />

            <ImageButton
                android:id="@+id/portal_action_format"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/format"
                android:src="@drawable/ic_format_bold_black_24dp"
                app:tint="@color/dark__primary_text" />

            <ImageButton
                android:id="@+id/portal_action_tags"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/tags"
                android:src="@drawable/ic_new_label_black_24dp"
                app:tint="@color/dark__primary_text" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                android:id="@+id/portal_save_fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save_session"
                app:backgroundTint="@color/accent"
                app:iconTint="@color/white"
                app:rippleColor="@color/white"
                app:textColor="@color/white" />
        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
