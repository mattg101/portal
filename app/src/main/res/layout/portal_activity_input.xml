<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/portal_drawer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/portal_main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/portal_content_column"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="156dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/portal_top_toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                app:navigationIcon="@android:drawable/ic_menu_sort_by_size"
                app:titleCentered="false"
                app:titleTextColor="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp">

                <EditText
                    android:id="@+id/portal_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/portal_title_hint"
                    android:imeOptions="actionNext"
                    android:includeFontPadding="false"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:minHeight="34dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="@color/primary_text"
                    android:textColorHint="@color/secondary_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/portal_open_settings_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginEnd="0dp"
                    android:text="@string/portal_settings"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    app:cornerRadius="16dp"
                    app:strokeColor="@color/primary" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/portal_open_classification_button"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:minHeight="48dp"
                        android:minWidth="148dp"
                        android:paddingStart="20dp"
                        android:paddingTop="0dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="0dp"
                        android:text="@string/portal_open_classification"
                        android:textAllCaps="false"
                        android:textColor="@color/primary_text"
                        android:textStyle="bold"
                        app:backgroundTint="@color/portal_chip_unselected_bg"
                        app:cornerRadius="10dp"
                        app:rippleColor="@color/accent" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/portal_tags_container"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="-1dp">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center_vertical"
                        android:fillViewport="true"
                        android:scrollbarStyle="outsideOverlay"
                        android:scrollbars="none">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/portal_quick_tags_group"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                app:chipSpacingHorizontal="8dp"
                                app:chipSpacingVertical="0dp"
                                app:singleLine="true" />
                        </FrameLayout>
                    </HorizontalScrollView>

                </FrameLayout>

                <View
                    android:id="@+id/portal_section_divider_format_top"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="2dp"
                    android:background="@color/portal_divider" />

                <HorizontalScrollView
                    android:id="@+id/portal_format_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fillViewport="true"
                    android:scrollbars="none">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/portal_format_row"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_heading"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/portal_format_heading"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/format_header_1"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_heading2"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Heading 2"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/format_header_2"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_bold"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/bold"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_format_bold_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_italic"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/italic"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_format_italic_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_underline"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/underline"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_format_underlined_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_bullets"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/unordered_list"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_list_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_numbers"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/portal_format_numbers"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_format_list_numbered_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_quote"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:contentDescription="@string/portal_format_quote"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_format_quote_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_link"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:contentDescription="@string/insert_link"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_link_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/portal_format_code"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:contentDescription="@string/code"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            app:backgroundTint="@android:color/transparent"
                            app:icon="@drawable/ic_code_black_24dp"
                            app:iconPadding="0dp"
                            app:iconTint="@color/primary_text"
                            app:rippleColor="@color/accent" />
                    </LinearLayout>
                    </FrameLayout>
                </HorizontalScrollView>

                <View
                    android:id="@+id/portal_editor_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/portal_divider" />

                <TextView
                    android:id="@+id/portal_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/secondary_text"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="6dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <EditText
                    android:id="@+id/portal_editor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="@string/portal_editor_hint"
                    android:imeOptions="flagNoExtractUi"
                    android:inputType="textCapSentences|textMultiLine"
                    android:padding="16dp"
                    android:textColor="@color/primary_text"
                    android:textColorHint="@color/secondary_text"
                    android:textCursorDrawable="@drawable/cursor_accent"
                    android:textSize="20sp" />

                <WebView
                    android:id="@+id/portal_preview_web"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
            </FrameLayout>

            <HorizontalScrollView
                android:id="@+id/portal_attachment_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="20dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/portal_attachment_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/portal_bottom_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/portal_publish_arc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingTop="2dp"
                android:paddingEnd="12dp"
                android:paddingBottom="2dp">

                <ImageView
                    android:id="@+id/portal_swipe_chevron_top"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:alpha="0.52"
                    android:background="@drawable/portal_swipe_chevron_circle"
                    android:padding="10dp"
                    android:src="@drawable/ic_baseline_keyboard_arrow_up_24"
                    app:tint="#FFF5EEE9" />

                <ImageView
                    android:id="@+id/portal_swipe_chevron_bottom"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:alpha="0"
                    android:src="@drawable/ic_baseline_keyboard_arrow_up_24"
                    android:visibility="gone"
                    app:tint="#FFD9C8" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portal_floating_dock"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/portal_floating_dock_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:elevation="18dp">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:foregroundGravity="center"
                    android:padding="4dp">

                    <View
                        android:id="@+id/portal_record_pulse_ring"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:background="@drawable/portal_record_pulse_ring"
                        android:visibility="gone" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/portal_action_record"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:background="@null"
                        android:contentDescription="@string/record_audio"
                        android:padding="0dp"
                        android:scaleType="center"
                        android:src="@drawable/ic_keyboard_voice_black_24dp"
                        app:tint="@color/white" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:foregroundGravity="center"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/portal_action_camera"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/image"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:text=""
                        app:backgroundTint="@android:color/transparent"
                        app:icon="@drawable/ic_photo_camera_black_24dp"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="#F4F4F8" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:foregroundGravity="center"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/portal_action_gallery"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/portal_gallery"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:text=""
                        app:backgroundTint="@android:color/transparent"
                        app:icon="@drawable/ic_image_black_24dp"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="#F4F4F8" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/portal_send_flash_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="@drawable/portal_send_vignette"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/portal_classification_drawer"
        android:layout_width="304dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginStart="28dp"
        android:background="@drawable/portal_classification_drawer_bg"
        android:elevation="12dp"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:text="@string/portal_classification"
            android:textColor="@color/primary_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <LinearLayout
                android:id="@+id/portal_classification_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <Space
                android:layout_width="match_parent"
                android:layout_height="56dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/portal_class_add_custom"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="end"
                android:layout_marginEnd="18dp"
                android:contentDescription="@string/portal_add_classification"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text=""
                app:backgroundTint="@color/accent"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_add_white_24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/white"
                app:rippleColor="@color/white"
                app:strokeColor="@color/accent" />
        </FrameLayout>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
